# Database
POSTGRES_USER=user_dev
POSTGRES_PASSWORD=change_me
POSTGRES_DB=healthcare
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5434/${POSTGRES_DB}
PG_TRGM_SIMILARITY_THRESHOLD=0.2

# OpenTelemetry (optional; leave empty to disable OTLP export)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=healthcare-api
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0

# Document storage (MinIO / S3-compatible)
DOCUMENT_STORAGE_ENDPOINT=http://localhost:9000
DOCUMENT_STORAGE_BUCKET=patient-notes
DOCUMENT_STORAGE_ACCESS_KEY=minioadmin
DOCUMENT_STORAGE_SECRET_KEY=minioadmin
# Optional MinIO root credentials used by docker-compose provisioning
# Keep DOCUMENT_STORAGE_* as an app-scoped user when possible.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Vector / embeddings (optional; leave empty to skip embedding pipeline)
VECTOR_EMBEDDING_MODEL=text-embedding-3-small
VECTOR_EMBEDDING_DIMENSIONS=1536
OPENAI_API_KEY=

# Summary and chat (required for GET /patients/{id}/summary and POST /patients/{id}/chat)
OPENAI_SUMMARY_MODEL=gpt-4o-mini
OPENAI_CHAT_MODEL=gpt-4o-mini

# Environment
ENVIRONMENT=development
